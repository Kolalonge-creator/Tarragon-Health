# Tarragon Health — environment variable catalogue (ARCHITECTURE.md §14).
# Copy to .env.local and fill in. Only NEXT_PUBLIC_* vars reach the browser.
# Never commit real secrets. X-Service-Key must never appear in git history.

# --- Supabase (eu-west-1; no Africa region available, NDPR residency gap accepted) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Trusted server / Edge Function contexts only — never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# --- Python ML microservice (services/ml) ---
# TypeScript -> ML over HTTP only, 5s timeout, graceful fallback.
ML_SERVICE_URL=http://localhost:8000
ML_SERVICE_KEY=

# --- Upstash Redis (cache / queues / WhatsApp conversation state) ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- WhatsApp Cloud API (primary patient channel) ---
# Also required as Edge Function secrets (`supabase functions secrets set` or
# the dashboard) — supabase/functions/send-pending-notifications reads these
# from the isolated Deno runtime, not from this file / .env.local.
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_VERIFY_TOKEN=
# App Dashboard > Settings > Basic > App Secret. Optional but recommended —
# whatsapp-webhook validates inbound POSTs against this via
# X-Hub-Signature-256; without it, signature checking is skipped (logged to
# audit_log each time, never a crash).
WHATSAPP_APP_SECRET=

# --- Termii SMS (fallback channel) ---
# Also required as an Edge Function secret, same as WHATSAPP_* above.
TERMII_API_KEY=

# --- Payments: Paystack (NGN) ---
# NGN/Paystack only this pass (Sprint 6) — Stripe/GBP diaspora billing is a
# follow-up. PAYSTACK_SECRET_KEY is used server-side only
# (apps/web/src/lib/paystack/) — hosted-checkout redirect flow keeps card
# data off our servers, no NEXT_PUBLIC_ key needed.
PAYSTACK_SECRET_KEY=
# Also required as an Edge Function secret (`supabase functions secrets set
# PAYSTACK_WEBHOOK_SECRET=... PAYSTACK_SECRET_KEY=...`) — the isolated Deno
# runtime running supabase/functions/paystack-webhook doesn't read this
# file. Register the webhook URL in the Paystack dashboard (Settings > API
# Keys & Webhooks) as:
#   https://koiplnmbgnqnbywhpjlf.supabase.co/functions/v1/paystack-webhook
PAYSTACK_WEBHOOK_SECRET=

# --- Payments: Stripe (GBP/USD diaspora) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- AI orchestration: Claude / LangGraph.js ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5
# Cost control: max AI Coach messages per patient per Africa/Lagos day.
AI_COACH_DAILY_MESSAGE_LIMIT=20
