# Tarragon Health — environment variable catalogue (ARCHITECTURE.md §14).
# Copy to .env.local and fill in. Only NEXT_PUBLIC_* vars reach the browser.
# Never commit real secrets. X-Service-Key must never appear in git history.

# --- Supabase (eu-west-1; no Africa region available, NDPR residency gap accepted) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Trusted server / Edge Function contexts only — never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# --- Python ML microservice (services/ml) ---
# TypeScript -> ML over HTTP only, 5s timeout, graceful fallback.
ML_SERVICE_URL=http://localhost:8000
ML_SERVICE_KEY=

# --- Mobile app (apps/mobile) — same Supabase project, EXPO_PUBLIC_* is the
# Expo equivalent of NEXT_PUBLIC_* (bundled client-side, no secrets here).
# Belongs in apps/mobile/.env.local, not the root — listed here for the
# single environment-variable catalogue per ARCHITECTURE.md §14.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
# apps/web deployment URL — the mobile app POSTs decoded BLE device
# readings to its /api/mobile/device-readings route (bearer-token
# authenticated, no cookie session available on mobile).
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000

# --- Upstash Redis (cache / queues / WhatsApp conversation state) ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- WhatsApp Cloud API (primary patient channel) ---
# Also required as Edge Function secrets (`supabase functions secrets set` or
# the dashboard) — supabase/functions/send-pending-notifications reads these
# from the isolated Deno runtime, not from this file / .env.local.
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_VERIFY_TOKEN=
# App Dashboard > Settings > Basic > App Secret. Optional but recommended —
# whatsapp-webhook validates inbound POSTs against this via
# X-Hub-Signature-256; without it, signature checking is skipped (logged to
# audit_log each time, never a crash).
WHATSAPP_APP_SECRET=

# --- Termii SMS (fallback channel) ---
# Also required as an Edge Function secret, same as WHATSAPP_* above.
TERMII_API_KEY=

# --- Payments: Paystack (NGN) ---
# NGN/Paystack only this pass (Sprint 6) — Stripe/GBP diaspora billing is a
# follow-up. PAYSTACK_SECRET_KEY is used server-side only
# (apps/web/src/lib/paystack/) — hosted-checkout redirect flow keeps card
# data off our servers, no NEXT_PUBLIC_ key needed.
PAYSTACK_SECRET_KEY=
# Also required as an Edge Function secret (`supabase functions secrets set
# PAYSTACK_WEBHOOK_SECRET=... PAYSTACK_SECRET_KEY=...`) — the isolated Deno
# runtime running supabase/functions/paystack-webhook doesn't read this
# file. Register the webhook URL in the Paystack dashboard (Settings > API
# Keys & Webhooks) as:
#   https://koiplnmbgnqnbywhpjlf.supabase.co/functions/v1/paystack-webhook
PAYSTACK_WEBHOOK_SECRET=

# --- Payments: Stripe (GBP/USD diaspora) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Video consultations: Zoom (pre-referral triage + telemedicine-first
# specialist consults, docs/Tarragon_Health_Master_Operating_Plan_v4.md §7) ---
# Server-to-Server OAuth (Zoom's current recommendation for a backend that
# creates meetings with no interactive user consent — the older JWT app
# type is deprecated). apps/web/src/lib/zoom/client.ts degrades gracefully
# (isZoomConfigured() returns false) when unset.
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
# Also required as an Edge Function secret (`supabase functions secrets set
# ZOOM_WEBHOOK_SECRET_TOKEN=...`) — the isolated Deno runtime running
# supabase/functions/zoom-webhook doesn't read this file. This is the exact
# gotcha the Stripe webhook hit (2026-07-15 sprint log): a secret set only
# in .env.local silently no-ops the deployed webhook, still returning
# HTTP 200, so Zoom never retries and the failure is invisible until
# specifically checked. Register the webhook URL in the Zoom App
# Marketplace (Feature > Event Subscriptions) as:
#   https://koiplnmbgnqnbywhpjlf.supabase.co/functions/v1/zoom-webhook
ZOOM_WEBHOOK_SECRET_TOKEN=

# --- Consumer wearable cloud sync (Phase 3, diaspora/premium tier, not yet
# built) --- apps/web/src/lib/wearables/oauth-providers.ts degrades
# gracefully (never throws) when any of these are unset. Apple Health has no
# cloud OAuth API at all — it's a mobile HealthKit bridge, not a server-side
# credential, so it has no entry here.
OURA_CLIENT_ID=
OURA_CLIENT_SECRET=
WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=
GARMIN_CLIENT_ID=
GARMIN_CLIENT_SECRET=
FITBIT_CLIENT_ID=
FITBIT_CLIENT_SECRET=

# --- AI orchestration: Claude / LangGraph.js ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5
# Cost control: max AI Coach messages per patient per Africa/Lagos day.
AI_COACH_DAILY_MESSAGE_LIMIT=20

# --- Error tracking: Sentry (apps/web) ---
# Optional — unset means Sentry.init() is never called (see
# apps/web/src/sentry.server.config.ts), same opt-in pattern as
# services/ml's SENTRY_DSN. Both vars should be set to the same DSN value:
# the NEXT_PUBLIC_ one reaches the browser bundle, the bare one is read
# server/edge-side. A DSN is not a secret.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
# Optional, build-time only (source map upload) — safe to leave unset;
# upload is silently skipped without them, per apps/web/next.config.ts.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
