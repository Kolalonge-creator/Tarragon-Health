# services/ml — environment template. Copy to .env for local dev.
# NEVER commit a real .env or a real ML_SERVICE_KEY (see docs/ARCHITECTURE.md §secrets).

# Shared secret the TypeScript platform sends as the X-Service-Key header.
# Must match ML_SERVICE_KEY on the platform side. Required in production.
ML_SERVICE_KEY=

# development | test | production
ENVIRONMENT=development

# Optional. Sentry DSN for error tracking — leave unset to run with no
# Sentry dependency at all (sentry_sdk.init() is skipped entirely).
SENTRY_DSN=
