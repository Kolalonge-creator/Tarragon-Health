{
  "name": "@tarragon/mobile",
  "version": "0.1.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "build:dev:ios": "eas build --profile development --platform ios",
    "build:dev:android": "eas build --profile development --platform android",
    "build:preview:android": "eas build --profile preview --platform android",
    "build:prod": "eas build --profile production --platform all",
    "update:prod": "eas update --branch production --message",
    "typecheck": "tsc --noEmit",
    "lint": "eslint ."
  },
  "dependencies": {
    "@babel/runtime": "^7.25.0",
    "@react-native/assets-registry": "0.74.87",
    "@expo/vector-icons": "^14.0.3",
    "@supabase/supabase-js": "^2.45.4",
    "@tarragon/shared": "workspace:*",
    "expo": "~51.0.0",
    "expo-secure-store": "~13.0.2",
    "react": "18.2.0",
    "react-native": "0.74.5",
    "react-native-ble-plx": "^3.2.1",
    "react-native-url-polyfill": "^2.0.0",
    "react-native-webview": "13.8.6"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/node": "^20.19.43",
    "@types/react": "~18.2.79",
    "babel-preset-expo": "~11.0.0",
    "eslint": "^9",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8"
  }
}
